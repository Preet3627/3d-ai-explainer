{
  "name": "3d-ai-explainer",
  "version": "0.1.1",
  "author": {
    "name": "Latestinssan",
    "email": "preetjgfilj2@gmail.com"
  },
  "description": "Desktop app: 3D visualization with AI voice explanations. 2D image to 3D model generation with real-time voice interaction.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "lint": "tsc --noEmit && eslint src/",
    "typecheck": "tsc --noEmit",
    "python:setup": "bash scripts/setup-python.sh",
    "python:server": "cd python-backend && uvicorn server:app --host 127.0.0.1 --port 8765 --reload",
    "models:download": "bash scripts/download-models.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/groq": "^3.0.42",
    "@ai-sdk/openai": "^3.0.72",
    "ai": "^6.0.207",
    "dotenv": "^17.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.170.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.170.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.aiexplainer.app",
    "productName": "3D AI Explainer",
    "files": [
      "out/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.education"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "extraResources": [
      {
        "from": "python-backend",
        "to": "python-backend"
      }
    ]
  }
}
