# ─── API Keys (Required) ──────────────────────────────────────────
# At least ONE LLM provider key + Deepgram key are needed

DEEPGRAM_API_KEY="your_deepgram_api_key_here"

# LLM Providers (Vercel AI SDK) – uncomment the ones you use
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_API_KEY="AIza..."
GROQ_API_KEY="gsk_..."
XAI_API_KEY="xai-..."  # Grok

# ─── Ollama (Local LLM) ───────────────────────────────────────────
# No API key needed. Install Ollama from https://ollama.ai
# Then: ollama pull llama3.2
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="llama3.2"

# ─── Python Backend (for TripoSR / Stable Diffusion) ──────────────
PYTHON_BACKEND_URL="http://127.0.0.1:8765"

# ─── App Config ───────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER="ollama"  # ollama | openai | anthropic | google | groq | xai
MODELS_DIR="./src/assets/models"
UPLOADS_DIR="./uploads"
